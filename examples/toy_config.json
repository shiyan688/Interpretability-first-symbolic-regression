{
  "input_csv": "toy_regression.csv",
  "output_root": "../outputs/toy_regression_run",
  "targets": [
    "y"
  ],
  "dataset": {
    "format": "tabular_csv_v1",
    "encoding": "utf-8-sig",
    "id_columns": [
      "sample_id"
    ],
    "target_columns": [
      "y"
    ],
    "target_rules": {
      "prefixes": [],
      "regex": [],
      "exclude": []
    },
    "feature_rules": {
      "include": [],
      "regex": [],
      "exclude": [],
      "exclude_regex": [],
      "numeric_only": true
    },
    "missing": {
      "fill": "median",
      "add_indicators": true
    },
    "scaling": "zscore",
    "naming": {
      "safe_prefix": "raw_",
      "max_length": 96
    }
  },
  "raw_feature_selection": {
    "mode": "all"
  },
  "factor_mining": {
    "base_top_k": 20,
    "pair_top_k": 30,
    "beam_width": 120,
    "final_top_k": 300,
    "max_order": 2,
    "unary_ops": [
      "abs",
      "square",
      "inv",
      "sqrt_abs",
      "log_abs"
    ],
    "binary_ops": [
      "+",
      "-",
      "*",
      "/"
    ],
    "max_abs_value": 1000000000000.0
  },
  "factor_selection": {
    "raw_top_fraction": 0.3,
    "factor_top_k": 200,
    "llm_keep_extra_top_k": 200
  },
  "pysr": {
    "maxsize": 30,
    "procs": 4,
    "population_size": 80,
    "populations": 12,
    "niterations": 10000,
    "timeout_seconds": 600,
    "parsimony": 1e-6,
    "model_selection": "accuracy",
    "seed": 20260709
  }
}

