  "formulas": [
    {"task_id": "F01_free_fall", "name": "自由落体距离", "expression": "0.5 * 9.8 * t**2", "variables": [{"name": "t", "low": 0.5, "high": 5.0, "meaning": "time"}], "regressible": true, "complexity": "simple"},
    {"task_id": "F02_time_dilation", "name": "相对论时间膨胀", "expression": "t0 / sqrt(1 - beta**2)", "variables": [{"name": "t0", "low": 1.0, "high": 5.0, "meaning": "proper time"}, {"name": "beta", "low": 0.05, "high": 0.9, "meaning": "v/c"}], "regressible": true, "complexity": "simple"},
    {"task_id": "F03_length_contraction", "name": "相对论长度收缩", "expression": "x0 * sqrt(1 - beta**2)", "variables": [{"name": "x0", "low": 1.0, "high": 5.0, "meaning": "proper length"}, {"name": "beta", "low": 0.05, "high": 0.9, "meaning": "v/c"}], "regressible": true, "complexity": "simple"},
    {"task_id": "F04_coulomb_force", "name": "库仑定律", "expression": "q1 * q2 / r**2", "variables": [{"name": "q1", "low": 0.5, "high": 3.0, "meaning": "charge 1"}, {"name": "q2", "low": 0.5, "high": 3.0, "meaning": "charge 2"}, {"name": "r", "low": 0.5, "high": 3.0, "meaning": "distance"}], "regressible": true, "complexity": "simple"},
    {"task_id": "F05_gravitation", "name": "万有引力", "expression": "m1 * m2 / r**2", "variables": [{"name": "m1", "low": 0.5, "high": 3.0, "meaning": "mass 1"}, {"name": "m2", "low": 0.5, "high": 3.0, "meaning": "mass 2"}, {"name": "r", "low": 0.5, "high": 3.0, "meaning": "distance"}], "regressible": true, "complexity": "simple"},
    {"task_id": "F06_ideal_gas", "name": "理想气体状态方程", "expression": "n * 8.314 * T / V", "variables": [{"name": "n", "low": 0.5, "high": 3.0, "meaning": "moles"}, {"name": "T", "low": 100.0, "high": 400.0, "meaning": "temperature"}, {"name": "V", "low": 0.5, "high": 3.0, "meaning": "volume"}], "regressible": true, "complexity": "simple"},
    {"task_id": "F07_doppler", "name": "多普勒频移", "expression": "f0 / (1 - beta)", "variables": [{"name": "f0", "low": 1.0, "high": 5.0, "meaning": "source frequency"}, {"name": "beta", "low": 0.05, "high": 0.8, "meaning": "v/c"}], "regressible": true, "complexity": "simple"},
    {"task_id": "F08_snell", "name": "折射定律(arcsin)", "expression": "asin(n * sin(theta2))", "variables": [{"name": "n", "low": 1.0, "high": 1.4, "meaning": "refractive index"}, {"name": "theta2", "low": 0.1, "high": 0.5, "meaning": "refraction angle (rad)"}], "regressible": true, "complexity": "simple"},
    {"task_id": "F09_gaussian_std", "name": "一维高斯分布", "expression": "exp(-(theta**2)/2) / sqrt(2*pi)", "variables": [{"name": "theta", "low": -3.0, "high": 3.0, "meaning": "standardized variable"}], "regressible": true, "complexity": "medium"},
    {"task_id": "F10_gaussian_full", "name": "带均值方差高斯", "expression": "exp(-(((theta - theta1)/sigma)**2)/2) / (sqrt(2*pi)*sigma)", "variables": [{"name": "theta", "low": -2.0, "high": 2.0, "meaning": "variable"}, {"name": "theta1", "low": -1.0, "high": 1.0, "meaning": "mean"}, {"name": "sigma", "low": 0.5, "high": 2.0, "meaning": "std"}], "regressible": true, "complexity": "medium"},
    {"task_id": "F11_harmonic_wave", "name": "简谐波位移", "expression": "A * cos(omega * t + phi)", "variables": [{"name": "A", "low": 0.5, "high": 3.0, "meaning": "amplitude"}, {"name": "omega", "low": 0.5, "high": 3.0, "meaning": "angular frequency"}, {"name": "t", "low": 0.0, "high": 3.0, "meaning": "time"}, {"name": "phi", "low": 0.0, "high": 3.0, "meaning": "phase"}], "regressible": true, "complexity": "medium"},
    {"task_id": "F12_rel_momentum", "name": "相对论动量", "expression": "m * v / sqrt(1 - (v/3.0)**2)", "variables": [{"name": "m", "low": 0.5, "high": 3.0, "meaning": "mass"}, {"name": "v", "low": 0.1, "high": 2.5, "meaning": "speed (c=3)"}], "regressible": true, "complexity": "medium"},
    {"task_id": "F13_arrhenius", "name": "阿伦尼乌斯方程", "expression": "A * exp(-Ea / (8.314 * T))", "variables": [{"name": "A", "low": 1.0, "high": 5.0, "meaning": "pre-exponential"}, {"name": "Ea", "low": 1000.0, "high": 5000.0, "meaning": "activation energy"}, {"name": "T", "low": 200.0, "high": 500.0, "meaning": "temperature"}], "regressible": true, "complexity": "medium"},
    {"task_id": "F14_van_der_waals", "name": "范德瓦尔斯方程(显式P)", "expression": "n * 8.314 * T / (V - n*0.03) - 0.5 * n**2 / V**2", "variables": [{"name": "n", "low": 0.5, "high": 2.0, "meaning": "moles"}, {"name": "T", "low": 200.0, "high": 400.0, "meaning": "temperature"}, {"name": "V", "low": 1.0, "high": 3.0, "meaning": "volume"}], "regressible": true, "complexity": "medium"},
    {"task_id": "F15_michaelis_menten", "name": "米氏方程", "expression": "Vmax * S / (Km + S)", "variables": [{"name": "S", "low": 0.1, "high": 5.0, "meaning": "substrate conc"}, {"name": "Vmax", "low": 1.0, "high": 5.0, "meaning": "max rate"}, {"name": "Km", "low": 0.5, "high": 3.0, "meaning": "Michaelis constant"}], "regressible": true, "complexity": "medium"},
    {"task_id": "F16_coulomb_potential", "name": "库仑势能", "expression": "q1 * q2 / r", "variables": [{"name": "q1", "low": 0.5, "high": 3.0, "meaning": "charge 1"}, {"name": "q2", "low": 0.5, "high": 3.0, "meaning": "charge 2"}, {"name": "r", "low": 0.5, "high": 3.0, "meaning": "distance"}], "regressible": true, "complexity": "medium"},
    {"task_id": "F17_pendulum", "name": "单摆周期", "expression": "2 * pi * sqrt(L / 9.8)", "variables": [{"name": "L", "low": 0.2, "high": 3.0, "meaning": "length"}], "regressible": true, "complexity": "medium"},
    {"task_id": "F18_rc_charge", "name": "RC充电电压", "expression": "V0 * (1 - exp(-t / (R * C)))", "variables": [{"name": "V0", "low": 1.0, "high": 5.0, "meaning": "source voltage"}, {"name": "R", "low": 0.5, "high": 3.0, "meaning": "resistance"}, {"name": "C", "low": 0.5, "high": 3.0, "meaning": "capacitance"}, {"name": "t", "low": 0.1, "high": 5.0, "meaning": "time"}], "regressible": true, "complexity": "medium"},
    {"task_id": "F19_logistic_growth", "name": "逻辑斯蒂增长(ODE右端)", "expression": "r * N * (1 - N / K)", "variables": [{"name": "r", "low": 0.5, "high": 3.0, "meaning": "growth rate"}, {"name": "N", "low": 0.1, "high": 5.0, "meaning": "population"}, {"name": "K", "low": 5.0, "high": 10.0, "meaning": "capacity"}], "regressible": true, "complexity": "medium"},
    {"task_id": "F20_planck", "name": "普朗克黑体辐射", "expression": "(2 * omega**3) / (exp(omega / T) - 1)", "variables": [{"name": "omega", "low": 0.5, "high": 3.0, "meaning": "frequency (h,c,kb folded)"}, {"name": "T", "low": 1.0, "high": 5.0, "meaning": "temperature"}], "regressible": true, "complexity": "complex"},
    {"task_id": "F21_rel_kinetic_energy", "name": "相对论动能", "expression": "m * 9.0 * (1/sqrt(1 - (v/3.0)**2) - 1)", "variables": [{"name": "m", "low": 0.5, "high": 3.0, "meaning": "mass"}, {"name": "v", "low": 0.1, "high": 2.5, "meaning": "speed (c=3)"}], "regressible": true, "complexity": "complex"},
    {"task_id": "F22_grav_two_body", "name": "引力势能(两体)", "expression": "-m1 * m2 * (1/r2 - 1/r1)", "variables": [{"name": "m1", "low": 0.5, "high": 3.0, "meaning": "mass 1"}, {"name": "m2", "low": 0.5, "high": 3.0, "meaning": "mass 2"}, {"name": "r1", "low": 1.0, "high": 3.0, "meaning": "distance 1"}, {"name": "r2", "low": 1.0, "high": 3.0, "meaning": "distance 2"}], "regressible": true, "complexity": "complex"},
    {"task_id": "F23_dipole_potential", "name": "偶极势", "expression": "q * (1/r - p * cos(theta) / r**2)", "variables": [{"name": "q", "low": 0.5, "high": 3.0, "meaning": "charge"}, {"name": "r", "low": 1.0, "high": 3.0, "meaning": "distance"}, {"name": "p", "low": 0.5, "high": 2.0, "meaning": "dipole moment"}, {"name": "theta", "low": 0.0, "high": 3.0, "meaning": "angle"}], "regressible": true, "complexity": "complex"},
    {"task_id": "F24_boltzmann", "name": "玻尔兹曼分布", "expression": "n0 * exp(-m * 9.8 * x / (1.38 * T))", "variables": [{"name": "n0", "low": 1.0, "high": 5.0, "meaning": "base density"}, {"name": "m", "low": 0.5, "high": 3.0, "meaning": "mass"}, {"name": "x", "low": 0.1, "high": 2.0, "meaning": "height"}, {"name": "T", "low": 5.0, "high": 20.0, "meaning": "temperature (kb folded)"}], "regressible": true, "complexity": "complex"},
    {"task_id": "F25_compton", "name": "康普顿散射波长移", "expression": "2.4 * (1 - cos(theta))", "variables": [{"name": "theta", "low": 0.0, "high": 3.14, "meaning": "scattering angle"}], "regressible": true, "complexity": "complex"},
    {"task_id": "F26_kepler", "name": "开普勒第三定律", "expression": "4 * pi**2 * a**3 / (M + m)", "variables": [{"name": "a", "low": 1.0, "high": 3.0, "meaning": "semi-major axis"}, {"name": "M", "low": 1.0, "high": 5.0, "meaning": "mass M"}, {"name": "m", "low": 0.1, "high": 2.0, "meaning": "mass m"}], "regressible": true, "complexity": "complex"},
    {"task_id": "F27_rel_doppler_angle", "name": "相对论多普勒(含角度)", "expression": "f0 * (1 - beta * cos(theta)) / sqrt(1 - beta**2)", "variables": [{"name": "f0", "low": 1.0, "high": 5.0, "meaning": "source frequency"}, {"name": "beta", "low": 0.05, "high": 0.8, "meaning": "v/c"}, {"name": "theta", "low": 0.0, "high": 3.14, "meaning": "angle"}], "regressible": true, "complexity": "complex"},
    {"task_id": "F28_lorentz_force", "name": "洛伦兹力分量", "expression": "q * (Ef + B * v * sin(theta))", "variables": [{"name": "q", "low": 0.5, "high": 3.0, "meaning": "charge"}, {"name": "Ef", "low": 0.5, "high": 3.0, "meaning": "E field"}, {"name": "B", "low": 0.5, "high": 3.0, "meaning": "B field"}, {"name": "v", "low": 0.5, "high": 3.0, "meaning": "speed"}, {"name": "theta", "low": 0.0, "high": 3.14, "meaning": "angle"}], "regressible": true, "complexity": "complex"},
    {"task_id": "F29_diffusion", "name": "扩散方程基本解", "expression": "n0 * exp(-((x - mu)**2) / (4 * D * t)) / sqrt(4 * pi * D * t)", "variables": [{"name": "n0", "low": 1.0, "high": 5.0, "meaning": "amplitude"}, {"name": "x", "low": -2.0, "high": 2.0, "meaning": "position"}, {"name": "mu", "low": -1.0, "high": 1.0, "meaning": "center"}, {"name": "D", "low": 0.5, "high": 2.0, "meaning": "diffusion coef"}, {"name": "t", "low": 0.5, "high": 3.0, "meaning": "time"}], "regressible": true, "complexity": "complex"},
    {"task_id": "F30_lorenz_system", "name": "洛伦兹吸引子(ODE系统)", "expression": "sigma * (y - x)", "variables": [{"name": "sigma", "low": 5.0, "high": 15.0, "meaning": "parameter"}, {"name": "x", "low": -5.0, "high": 5.0, "meaning": "state x"}, {"name": "y", "low": -5.0, "high": 5.0, "meaning": "state y"}], "regressible": false, "complexity": "complex", "note": "Full system is 3 coupled ODEs; only the dx/dt component is a single-target regression target. Marked non-regressible for the standard single-target pipeline; included for completeness."}
